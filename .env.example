# ==========================================
# E106 환경변수 (템플릿)
# .env 파일로 복사 후 값을 채워주세요
# cp .env.example .env
# ==========================================

# Spring
APP_PROFILE=local

# MySQL
DB_HOSTNAME=mysql
DB_PORT=3306
MYSQL_DB=E106
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# JPA
DDL_AUTO=update

# Server
BACKEND_PORT=8080
TZ=Asia/Seoul
# JWT
JWT_SECRET=
JWT_ISSUER=e106
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600

# Redis
REDIS_HOSTNAME=redis
REDIS_PORT=6379

# OAuth (Social Login)
# Backend Google ID Token aud 검증에 사용
GOOGLE_CLIENT_ID=
KAKAO_CLIENT_ID=

# Firebase
# Firebase Admin SDK 서비스 계정 JSON을 base64로 인코딩한 값
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=

# Finance
FINANCE_API_KEY=
FINANCE_INSTITUTION_CODE=00100
FINANCE_FINTECH_APP_NO=001
